{
  "name": "moshimoshi-server",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "server",
  "workspaceFolder": "/home/alice/server",
  "postAttachCommand": "git config --global core.pager \"less -FX\" && cp -f /home/alice/server/.devcontainer/pre-commit /home/alice/server/.git/hooks/",
  "shutdownAction": "stopCompose",
  "initializeCommand": "ls",
  "containerUser": "alice",
  "customizations": {
    "vscode": {
      "extensions": [
        "denoland.vscode-deno",
        "wmaurer.change-case",
        "sleistner.vscode-fileutils",
        "usernamehw.errorlens",
        "albymor.increment-selection",
        "huizhou.githd",
        "GitHub.github-vscode-theme",
        "naumovs.color-highlight",
        "GitHub.copilot",
        "lea21st.vscode-sql-formatter"
      ],
      "settings": {
        "deno.enablePaths": ["/home/alice/server"],
        "deno.enable": true,
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "/bin/bash" }
        },
        "editor.defaultFormatter": "denoland.vscode-deno",
        "workbench.colorTheme": "GitHub Dark Colorblind",
        "sql-formatter.uppercase": false,
        "[sql]": {
          "editor.defaultFormatter": "lea21st.vscode-sql-formatter"
        }
      }
    }
  }
}
